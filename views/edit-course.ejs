<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Course</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('partials/navbar', { fullname: fullname }) %>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="mb-4">Edit Course</h3>
                        <% if (error) { %>
                            <div class="alert alert-danger"><%= error %></div>
                        <% } %>
                        <form action="/courses/edit/<%= course._id %>" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Course Name</label>
                                <input type="text" class="form-control" name="courseName" value="<%= course.courseName %>" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Trainer Name</label>
                                <input type="text" class="form-control" name="trainerName" value="<%= course.trainerName %>" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Duration</label>
                                <input type="text" class="form-control" name="duration" value="<%= course.duration %>" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Fees</label>
                                <input type="number" class="form-control" name="fees" value="<%= course.fees %>" required>
                            </div>
                            <button type="submit" class="btn btn-primary">Update</button>
                            <a href="/courses" class="btn btn-secondary">Cancel</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>