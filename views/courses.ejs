<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Courses</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('partials/navbar', { fullname: fullname }) %>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>Courses</h3>
            <a href="/courses/create" class="btn btn-success">+ Add Course</a>
        </div>
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Course Name</th>
                            <th>Trainer Name</th>
                            <th>Duration</th>
                            <th>Fees</th>
                            <th style="width:180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% courses.forEach(c => { %>
                        <tr>
                            <td><%= c.courseName %></td>
                            <td><%= c.trainerName %></td>
                            <td><%= c.duration %></td>
                            <td>₹<%= c.fees %></td>
                            <td>
                                <a href="/courses/edit/<%= c._id %>" class="btn btn-sm btn-warning">Edit</a>
                                <form action="/courses/delete/<%= c._id %>" method="POST" class="d-inline"
                                      onsubmit="return confirm('Delete this course?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                        <% if (courses.length === 0) { %>
                        <tr><td colspan="5" class="text-center text-muted">No courses added yet.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>