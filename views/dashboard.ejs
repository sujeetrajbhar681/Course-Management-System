<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('partials/navbar', { fullname: fullname }) %>
    <div class="container">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3>Welcome, <%= fullname %>!</h3>
                <p class="text-muted">Manage your courses from here.</p>
                <a href="/courses" class="btn btn-primary">View Courses</a>
                <a href="/courses/create" class="btn btn-success">Add New Course</a>
            </div>
        </div>
    </div>
</body>
</html>